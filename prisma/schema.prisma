generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  TECHNICIAN
  REQUESTER
}

enum AssetStatus {
  ACTIVE
  DOWN
  MAINTENANCE
  RETIRED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceRequestStatus {
  NEW
  REVIEWED
  CONVERTED
  REJECTED
  CLOSED
}

enum WorkOrderType {
  PREVENTIVE
  CORRECTIVE
  BREAKDOWN
  INSPECTION
}

enum WorkOrderStatus {
  DRAFT
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_PART
  COMPLETED
  CLOSED
  CANCELLED
}

enum ChecklistItemType {
  BOOLEAN
  TEXT
  NUMBER
}

enum FrequencyType {
  DAILY
  WEEKLY
  MONTHLY
  EVERY_X_DAYS
}

enum NotificationType {
  WORK_ORDER_ASSIGNED
  WORK_ORDER_OVERDUE
  PM_DUE
  PM_OVERDUE
  LOW_STOCK
  SYSTEM
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  username             String               @unique
  name                 String
  phone                String?
  passwordHash         String
  role                 UserRole
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  maintenanceRequests  MaintenanceRequest[]
  assignedWorkOrders   WorkOrder[]          @relation("AssignedWorkOrders")
  supervisedWorkOrders WorkOrder[]          @relation("SupervisedWorkOrders")
  createdWorkOrders    WorkOrder[]          @relation("CreatedWorkOrders")
  workOrderLabors      WorkOrderLabor[]
  workOrderChecklists  WorkOrderChecklist[] @relation("ChecklistCheckedBy")
  notifications        Notification[]
  auditLogs            AuditLog[]
}

model Site {
  id         String               @id @default(cuid())
  name       String
  code       String               @unique
  address    String?
  isActive   Boolean              @default(true)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  locations  Location[]
  assets     Asset[]
  requests   MaintenanceRequest[]
  workOrders WorkOrder[]
}

model Location {
  id          String               @id @default(cuid())
  siteId      String
  parentId    String?
  name        String
  type        String?
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  site        Site                 @relation(fields: [siteId], references: [id])
  parent      Location?            @relation("LocationHierarchy", fields: [parentId], references: [id])
  children    Location[]           @relation("LocationHierarchy")
  assets      Asset[]
  requests    MaintenanceRequest[]
  workOrders  WorkOrder[]
}

model AssetCategory {
  id                 String              @id @default(cuid())
  name               String              @unique
  description        String?
  assets             Asset[]
  checklistTemplates ChecklistTemplate[]
}

model Asset {
  id                String               @id @default(cuid())
  assetCode         String               @unique
  name              String
  categoryId        String
  siteId            String
  locationId        String?
  manufacturer      String?
  model             String?
  serialNumber      String?
  purchaseDate      DateTime?
  installDate       DateTime?
  warrantyExpiry    DateTime?
  criticality       String?
  status            AssetStatus          @default(ACTIVE)
  specificationJson Json?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  category          AssetCategory        @relation(fields: [categoryId], references: [id])
  site              Site                 @relation(fields: [siteId], references: [id])
  location          Location?            @relation(fields: [locationId], references: [id])
  requests          MaintenanceRequest[]
  workOrders        WorkOrder[]
  pmSchedules       PMSchedule[]
}

model MaintenanceRequest {
  id          String                   @id @default(cuid())
  requestNo   String                   @unique
  requesterId String
  assetId     String?
  siteId      String
  locationId  String?
  title       String
  description String
  priority    PriorityLevel            @default(MEDIUM)
  status      MaintenanceRequestStatus @default(NEW)
  photoUrl    String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  requester   User                     @relation(fields: [requesterId], references: [id])
  asset       Asset?                   @relation(fields: [assetId], references: [id])
  site        Site                     @relation(fields: [siteId], references: [id])
  location    Location?                @relation(fields: [locationId], references: [id])
  workOrders  WorkOrder[]
}

model WorkOrder {
  id              String               @id @default(cuid())
  woNo            String               @unique
  type            WorkOrderType
  sourceRequestId String?
  assetId         String
  siteId          String
  locationId      String?
  title           String
  description     String
  priority        PriorityLevel        @default(MEDIUM)
  status          WorkOrderStatus      @default(OPEN)
  assignedToId    String?
  supervisorId    String?
  dueDate         DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  downtimeMinutes Int?
  rootCause       String?
  resolution      String?
  completionNote  String?
  createdById     String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  sourceRequest   MaintenanceRequest?  @relation(fields: [sourceRequestId], references: [id])
  asset           Asset                @relation(fields: [assetId], references: [id])
  site            Site                 @relation(fields: [siteId], references: [id])
  location        Location?            @relation(fields: [locationId], references: [id])
  assignedTo      User?                @relation("AssignedWorkOrders", fields: [assignedToId], references: [id])
  supervisor      User?                @relation("SupervisedWorkOrders", fields: [supervisorId], references: [id])
  createdBy       User                 @relation("CreatedWorkOrders", fields: [createdById], references: [id])
  labors          WorkOrderLabor[]
  parts           WorkOrderPart[]
  checklists      WorkOrderChecklist[]
}

model WorkOrderLabor {
  id           String    @id @default(cuid())
  workOrderId  String
  technicianId String
  startTime    DateTime?
  endTime      DateTime?
  hours        Decimal?  @db.Decimal(10, 2)
  note         String?
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id])
  technician   User      @relation(fields: [technicianId], references: [id])
}

model SparePart {
  id              String          @id @default(cuid())
  partCode        String          @unique
  name            String
  category        String?
  unit            String
  stockQty        Decimal         @default(0) @db.Decimal(12, 2)
  minStockQty     Decimal         @default(0) @db.Decimal(12, 2)
  storageLocation String?
  averageCost     Decimal?        @db.Decimal(12, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  workOrderParts  WorkOrderPart[]
}

model WorkOrderPart {
  id          String    @id @default(cuid())
  workOrderId String
  sparePartId String
  quantity    Decimal   @db.Decimal(12, 2)
  unitCost    Decimal?  @db.Decimal(12, 2)
  totalCost   Decimal?  @db.Decimal(12, 2)
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])
}

model ChecklistTemplate {
  id                  String                  @id @default(cuid())
  name                String
  assetCategoryId     String?
  description         String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  assetCategory       AssetCategory?          @relation(fields: [assetCategoryId], references: [id])
  items               ChecklistTemplateItem[]
  pmSchedules         PMSchedule[]
}

model ChecklistTemplateItem {
  id                  String                @id @default(cuid())
  templateId          String
  itemText            String
  itemType            ChecklistItemType     @default(BOOLEAN)
  isRequired          Boolean               @default(false)
  sortOrder           Int                   @default(0)
  template            ChecklistTemplate     @relation(fields: [templateId], references: [id])
  workOrderChecklists WorkOrderChecklist[]
}

model PMSchedule {
  id                  String             @id @default(cuid())
  assetId             String
  name                String
  description         String?
  frequencyType       FrequencyType
  frequencyValue      Int
  nextDueDate         DateTime?
  checklistTemplateId String?
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  asset               Asset              @relation(fields: [assetId], references: [id])
  checklistTemplate   ChecklistTemplate? @relation(fields: [checklistTemplateId], references: [id])
}

model WorkOrderChecklist {
  id             String                @id @default(cuid())
  workOrderId    String
  templateItemId String
  result         String?
  note           String?
  checkedById    String?
  checkedAt      DateTime?
  workOrder      WorkOrder             @relation(fields: [workOrderId], references: [id])
  templateItem   ChecklistTemplateItem @relation(fields: [templateItemId], references: [id])
  checkedBy      User?                 @relation("ChecklistCheckedBy", fields: [checkedById], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  action        String
  entityType    String
  entityId      String
  oldValuesJson Json?
  newValuesJson Json?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}
